rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // ── USERS ──────────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Tout utilisateur connecté peut lire un profil (noms, téléphones)
      allow read: if isSignedIn();

      // Création uniquement par le propriétaire du compte
      allow create: if isOwner(userId);

      // Suppression uniquement par le propriétaire
      allow delete: if isOwner(userId);

      // Mise à jour : règles strictes
      allow update: if isSignedIn() && (
        // Le propriétaire peut modifier ses infos de base SAUF champs sensibles
        (isOwner(userId) &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['bonusPoints', 'walletBalance', 'isVerified', 'referralCount', 'role']))
        ||
        // Attribution de points de parrainage (+10 uniquement) par un tiers (filleul)
        (!isOwner(userId) &&
          request.resource.data.bonusPoints == (resource.data.bonusPoints + 10) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bonusPoints']))
      );

      match /my_reviews/{reviewId} {
        allow read, write: if isOwner(userId);
      }

      match /transactions/{transId} {
        allow read: if isOwner(userId);
        // Le filleul peut créer une transaction chez le parrain
        allow create: if isSignedIn();
        // Personne ne peut modifier/supprimer une transaction
        allow update, delete: if false;
      }
    }

    // ── TRIPS ──────────────────────────────────────────────────────────────────

    match /trips/{tripId} {
      // Lecture : le client auteur, le chauffeur assigné, ou tout chauffeur (pour voir les demandes)
      allow read: if isSignedIn();

      // Création : tout utilisateur connecté peut créer une course pour lui-même
      allow create: if isSignedIn() &&
        request.resource.data.clientId == request.auth.uid &&
        request.resource.data.status == 'pending';

      // Mise à jour : règles granulaires
      allow update: if isSignedIn() && (
        // N'importe quel utilisateur connecté peut modifier le statut (acceptation, complétion)
        // mais pas changer le client ni le prix original
        (request.resource.data.clientId == resource.data.clientId &&
         request.resource.data.price == resource.data.price)
        ||
        // Le client peut annuler sa propre course si elle est encore 'pending'
        (isOwner(resource.data.clientId) &&
          resource.data.status == 'pending' &&
          request.resource.data.status == 'cancelled' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
      );

      // Suppression : uniquement par le client propriétaire si 'pending'
      allow delete: if isOwner(resource.data.clientId) &&
        resource.data.status == 'pending';
    }

    // ── POOLS (Covoiturage) ────────────────────────────────────────────────────

    match /pools/{poolId} {
      // Lecture : tout utilisateur connecté
      allow read: if isSignedIn();

      // Création : tout utilisateur connecté
      allow create: if isSignedIn();

      // Mise à jour : tout utilisateur connecté (rejoindre un pool, accepter, etc.)
      allow update: if isSignedIn();

      // Suppression interdite
      allow delete: if false;
    }

    // ── ACTIVE DRIVERS ─────────────────────────────────────────────────────────

    match /active_drivers/{driverId} {
      // Lecture : tout utilisateur connecté
      allow read: if isSignedIn();
      // Écriture : uniquement le chauffeur lui-même
      allow write: if isSignedIn() && isOwner(driverId);
    }

    // ── DRIVER ROUTES ──────────────────────────────────────────────────────────

    match /driver_routes/{driverId} {
      // Lecture : tout utilisateur connecté
      allow read: if isSignedIn();
      // Écriture : uniquement le chauffeur propriétaire
      allow write: if isSignedIn() && isOwner(driverId);
    }

    // ── REVIEWS ────────────────────────────────────────────────────────────────

    match /reviews/{reviewId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
    }
  }
}
