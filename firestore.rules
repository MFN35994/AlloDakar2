rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Global Admin Rule
    match /{path=**} {
      allow read, write: if isAdmin();
    }

    // ── USERS ──────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow delete: if isOwner(userId);
      allow update: if isSignedIn() && (
        (isOwner(userId) &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['bonusPoints', 'walletBalance', 'isVerified', 'referralCount']) &&
          (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) ||
            (!('role' in resource.data) || resource.data.role == 'none')
          )
        )
        ||
        (!isOwner(userId) &&
          request.resource.data.bonusPoints == (resource.data.bonusPoints + 10) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bonusPoints']))
      );

      match /my_reviews/{reviewId} {
        allow read, write: if isOwner(userId);
      }

      match /transactions/{transId} {
        allow read: if isOwner(userId);
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    // ── TRIPS ──────────────────────────────────────────────────────────────────

    match /trips/{tripId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.clientId == request.auth.uid &&
        request.resource.data.status == 'pending';

      allow update: if isSignedIn() && (
        // Autorise la mise à jour si on ne touche pas aux champs critiques (clientId, price)
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['clientId', 'price'])
      );

      allow delete: if isOwner(resource.data.clientId) &&
        resource.data.status == 'pending';
    }

    // ── POOLS (Covoiturage) ────────────────────────────────────────────────────

    match /pools/{poolId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ── ACTIVE DRIVERS ─────────────────────────────────────────────────────────

    match /active_drivers/{driverId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isOwner(driverId);
    }

    // ── DRIVER ROUTES ──────────────────────────────────────────────────────────

    match /driver_routes/{driverId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isOwner(driverId);
    }

    // ── REVIEWS ────────────────────────────────────────────────────────────────

    match /reviews/{reviewId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
    }

    // ── FAVORITES (In Users subcollections) ────────────────────────────────────

    match /users/{userId}/favorite_addresses/{favId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/favorite_drivers/{favId} {
      allow read, write: if isOwner(userId);
    }

    // ── CHAT MESSAGES (In Trips subcollections) ────────────────────────────────

    match /trips/{tripId}/messages/{msgId} {
      allow read: if isSignedIn(); 
      allow create: if isSignedIn();
    }

    match /pools/{poolId}/messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }
  }
}
